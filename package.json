{
  "name": "agent-control-center",
  "version": "1.0.0",
  "description": "Read-only monitoring center for Claude and Codex agents - monitor sessions from anywhere",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "cd client && npm run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "cd client && npm run build",
    "start": "node server/dist/index.js",
    "setup": "npm install && cd client && npm install",
    "test": "npm run build && npm run test:redact && npm run test:needs-review && ./smoke-test.sh && ./test-reports-api.sh",
    "test:redact": "npx tsx server/src/redact.test.ts",
    "test:needs-review": "npx tsx server/src/needs-review.test.ts",
    "test:smoke": "./smoke-test.sh",
    "test:reports": "./test-reports-api.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "concurrently": "^8.2.2",
    "puppeteer": "^25.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
