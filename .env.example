# Agent Control Center - Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

#############################################################################
# REQUIRED FOR PRODUCTION
#############################################################################

# Authentication token for API and WebSocket access
# Generate with: openssl rand -hex 32
AUTH_TOKEN=

#############################################################################
# OPTIONAL
#############################################################################

# Server configuration
NODE_ENV=production
PORT=9876

# CORS configuration (production recommended)
# Set to your client origin (e.g., http://your-ipad-ip:9876)
# Leave unset to allow all origins (NOT recommended for production)
# CORS_ORIGIN=http://your-tailscale-ip:9876

#############################################################################
# DEVELOPMENT NOTES
#############################################################################

# In development mode (NODE_ENV=development):
# - If AUTH_TOKEN is not set, a temporary token is auto-generated
# - Token is written to /tmp/agent-control-center-token
# - This is for convenience only - NOT suitable for production

# In production mode (NODE_ENV=production):
# - AUTH_TOKEN MUST be set or server will refuse to start
# - CORS_ORIGIN should be configured for security

#############################################################################
# SECURITY BEST PRACTICES
#############################################################################

# 1. NEVER commit .env to version control
# 2. Use a strong random token (32+ hex characters)
# 3. Rotate tokens periodically
# 4. Keep tokens in secure environment variable storage
# 5. Use Tailscale VPN for network-level security
# 6. Configure CORS_ORIGIN to limit access
